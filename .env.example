# ── RENTA-Z Environment Variables ──
# Copy this to .env.local and fill in your Supabase credentials

# Supabase (get from: https://supabase.com/dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your_anon_key_here

# Optional: Site URL for auth redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000
